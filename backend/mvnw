#!/bin/sh
# Maven Wrapper (simplified)
# Licensed under Apache License 2.0

MAVEN_HOME="$(cd "$(dirname "$0")" && pwd)/.mvn/wrapper"
MAVEN_JAR="$MAVEN_HOME/maven-wrapper.jar"
MAVEN_OPTS="${MAVEN_OPTS:-}"

if [ ! -f "$MAVEN_JAR" ]; then
  # Download the wrapper jar if not present
  W_JAR_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"
  if command -v curl > /dev/null 2>&1; then
    curl -sS -o "$MAVEN_JAR" "$W_JAR_URL"
  elif command -v wget > /dev/null 2>&1; then
    wget -q -O "$MAVEN_JAR" "$W_JAR_URL"
  fi
fi

exec java $MAVEN_OPTS -jar "$MAVEN_JAR" "$@"
